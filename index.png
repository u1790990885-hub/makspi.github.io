<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="UTF-8">
<title>Mini Windows 11 PL</title>
<style>
body{margin:0;font-family:"Segoe UI",sans-serif;background:#0c0c0c;overflow:hidden;color:white;}
/* Pulpit */
#desktop{
  display:none;
  width:100vw;height:100vh;
  background:linear-gradient(135deg,#1a1a1a,#2b2b3b);
  position:relative;
  overflow:hidden;
}

/* Pasek zadań */
.taskbar{
  position:absolute;bottom:0;width:100%;height:60px;
  background:rgba(40,40,50,0.5);
  backdrop-filter:blur(15px);
  display:flex;align-items:center;justify-content:center;
  z-index:999;
}
.task-icons{display:flex;gap:15px}
.icon{
  width:50px;height:50px;background:rgba(255,255,255,0.1);
  border-radius:12px;display:flex;align-items:center;justify-content:center;
  cursor:pointer;transition:.2s;font-size:24px;
}
.icon:hover{background:rgba(255,255,255,0.25)}

/* Menu start */
#start{
  position:absolute;bottom:70px;left:50%;transform:translateX(-50%);
  width:360px;background:rgba(25,25,35,0.9);
  backdrop-filter:blur(20px);
  border-radius:15px;padding:15px;display:none;opacity:0;
  transition:.3s;
}
#start.active{display:block;opacity:1}
.start-app{background:rgba(255,255,255,0.05);padding:10px;margin:5px;border-radius:10px;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:20px;transition:.2s;}
.start-app:hover{background:rgba(255,255,255,0.2);}

/* Okna */
.window{
  position:absolute;width:500px;height:350px;
  background:white;color:black;border-radius:15px;
  display:none;flex-direction:column;
  overflow:hidden;box-shadow:0 20px 40px rgba(0,0,0,.5);
  transform:scale(.95);opacity:0;transition:.2s;
}
.window.active{transform:scale(1);opacity:1}
.header{
  background:#0078d7;color:white;padding:10px;display:flex;justify-content:space-between;cursor:move;
}
#explorer #files{flex:1;padding:10px;overflow:auto;}
.file{padding:5px;margin:3px;border-radius:5px;cursor:pointer;}
.file:hover{background:rgba(0,0,0,.1);}

/* Terminal */
#terminal #termOut{flex:1;background:black;color:#0f0;padding:10px;overflow:auto;}
#termIn{padding:5px;background:#111;color:#0f0;border:none;outline:none;width:100%}

/* Gra */
#game canvas{background:black;width:100%;height:100%;display:block;}
</style>
</head>
<body>

<!-- Boot -->
<div id="boot" style="position:absolute;inset:0;background:black;display:flex;justify-content:center;align-items:center;font-size:28px;color:#0f0;">💻 Uruchamianie Mini Windows 11...</div>

<!-- Pulpit -->
<div id="desktop">

<!-- Menu start -->
<div id="start">
  <div class="start-app" onclick="install('Notatnik')">📝 Notatnik</div>
  <div class="start-app" onclick="openWin('explorer')">📁 Eksplorator</div>
  <div class="start-app" onclick="openWin('terminal')">💻 Terminal</div>
  <div class="start-app" onclick="openWin('game')">🎮 Snake</div>
</div>

<!-- Pasek zadań -->
<div class="taskbar">
  <div class="task-icons">
    <div class="icon" onclick="toggleStart()">🪟</div>
    <div class="icon" onclick="openWin('explorer')">📁</div>
    <div class="icon" onclick="openWin('terminal')">💻</div>
    <div class="icon" onclick="openWin('game')">🎮</div>
  </div>
</div>

<!-- Eksplorator -->
<div class="window" id="explorer">
  <div class="header">Eksplorator <button onclick="closeWin('explorer')">X</button></div>
  <div id="files"></div>
</div>

<!-- Terminal -->
<div class="window" id="terminal">
  <div class="header">Terminal <button onclick="closeWin('terminal')">X</button></div>
  <div id="termOut"></div>
  <input id="termIn" autocomplete="off" placeholder="Wpisz polecenie">
</div>

<!-- Gra -->
<div class="window" id="game">
  <div class="header">Snake <button onclick="closeWin('game')">X</button></div>
  <canvas id="snake" width="400" height="300"></canvas>
</div>

<!-- Notatnik -->
<div class="window" id="notepad">
  <div class="header">Notatnik <button onclick="closeWin('notepad')">X</button></div>
  <textarea style="flex:1;padding:10px;border:none;outline:none;"></textarea>
</div>

</div>

<script>
// BOOT
setTimeout(()=>{document.getElementById('boot').style.display='none';document.getElementById('desktop').style.display='block'},1500)

// OKNA
let z=1;
function openWin(id){
  let w=document.getElementById(id); w.style.display='flex';
  setTimeout(()=>w.classList.add('active'),10); w.style.zIndex=++z;
}
function closeWin(id){
  let w=document.getElementById(id); w.classList.remove('active');
  setTimeout(()=>w.style.display='none',200);
}

// PRZESUWANIE OKIEN
document.querySelectorAll('.window').forEach(w=>{
  let h=w.querySelector('.header');
  h.onmousedown=e=>{
    let x=e.clientX-w.offsetLeft;
    let y=e.clientY-w.offsetTop;
    w.style.zIndex=++z;
    document.onmousemove=e=>{
      w.style.left=e.pageX-x+'px';
      w.style.top=e.pageY-y+'px';
    }
    document.onmouseup=()=>document.onmousemove=null;
  }
});

// MENU START
function toggleStart(){start.classList.toggle('active');}

// SYSTEM PLIKÓW
let fs={"C:":{"Dokumenty":{"plik.txt":"Witaj w Mini Windows 11!"},"Gry":{"snake.txt":"Snake Game"}}};
let path=["C:"];
function render(){
  let cur=fs; path.forEach(p=>cur=cur[p]);
  files.innerHTML='';
  if(path.length>1){
    let back=document.createElement('div'); back.innerText='⬅️ ..'; 
    back.onclick=()=>{path.pop();render()};
    files.appendChild(back);
  }
  for(let f in cur){
    let d=document.createElement('div'); d.className='file';
    d.innerText=(typeof cur[f]==='object'?'📁 ':'📄 ')+f;
    d.onclick=()=>{if(typeof cur[f]==='object'){path.push(f);render()} else alert(cur[f])};
    files.appendChild(d);
  }
}
render();

// TERMINAL
termIn.onkeydown=e=>{
  if(e.key==='Enter'){
    termOut.innerHTML+=termIn.value+'<br>';termIn.value='';
    termOut.scrollTop=termOut.scrollHeight;
  }
}

// INSTALOWANIE APLIKACJI
function install(name){alert('Zainstalowano '+name);}

// SNAKE GAME
let canvas=document.getElementById('snake');let ctx=canvas.getContext('2d');
let snake=[[5,5]],dir=[1,0];let food=[Math.floor(Math.random()*40),Math.floor(Math.random()*30)];
setInterval(()=>{
  ctx.clearRect(0,0,400,300);
  snake.unshift([snake[0][0]+dir[0],snake[0][1]+dir[1]]);
  if(snake[0][0]===food[0]&&snake[0][1]===food[1]){
    food=[Math.floor(Math.random()*40),Math.floor(Math.random()*30)];
  } else snake.pop();
  ctx.fillStyle='lime';snake.forEach(p=>ctx.fillRect(p[0]*10,p[1]*10,10,10));
  ctx.fillStyle='red';ctx.fillRect(food[0]*10,food[1]*10,10,10);
},100);
document.onkeydown=e=>{
  if(e.key==='ArrowUp')dir=[0,-1];
  if(e.key==='ArrowDown')dir=[0,1];
  if(e.key==='ArrowLeft')dir=[-1,0];
  if(e.key==='ArrowRight')dir=[1,0];
}
</script>

</body>
</html>
